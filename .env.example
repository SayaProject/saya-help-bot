ENV=True

# Required: create this in BotFather. The bot display name should be:
# Saya Help Bot
TOKEN=

# Required: your numeric Telegram user ID and username without @.
OWNER_ID=
OWNER_USERNAME=

# Required: get these from https://my.telegram.org/apps
API_ID=
API_HASH=

# Local Docker Compose default. The compose file also sets this for the bot.
DATABASE_URL=postgresql://saya:saya_local_password@postgres:5432/saya_help_bot

# Telegram support group/channel username without @.
SUPPORT_CHAT=SayaProject

# Local polling mode.
WEBHOOK=False
ALLOW_EXCL=True
ALLOW_CHATS=True
INFOPIC=True
DEL_CMDS=True
STRICT_GBAN=True
WORKERS=8

# Optional services and role lists. Leave blank unless you already use them.
JOIN_LOGGER=
EVENT_LOGS=
DRAGONS=
DEV_USERS=
DEMONS=
WOLVES=
TIGERS=
BL_CHATS=
LOAD=
NO_LOAD=rss cleaner connection math
SPAMWATCH_API=
SPAMWATCH_SUPPORT_CHAT=SpamWatchSupport
CASH_API_KEY=
TIME_API_KEY=
AI_API_KEY=
WALL_API=
DONATION_LINK=
BAN_STICKER=
